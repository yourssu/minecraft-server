# ============================================================
# minecraft.yourssu.com — Nginx 설정 인수인계용 예제
# ============================================================
#
# 구성 개요
#   /          → BlueMap 3D 웹 지도  (Paper 컨테이너 내부 :8100)
#   /admin/    → MCSManager 관리 패널 (mcsmanager-web 컨테이너 :23333)
#   :24444 SSL → MCSManager 데몬 WebSocket (mcsmanager-daemon 컨테이너 :24444)
#
# 전제 조건
#   - Let's Encrypt 인증서: /etc/letsencrypt/live/minecraft.yourssu.com/
#   - certbot webroot 경로: /var/www/certbot
#   - Docker 네트워크: mc-proxy 외부 네트워크에 nginx·paper·mcsmanager 컨테이너 연결
#     (컨테이너명으로 업스트림 해석)
#   - resolver 127.0.0.11: Docker 내장 DNS (런타임 업스트림 해석)
# ============================================================

# ── HTTP: HTTPS 리디렉션 + certbot 챌린지 ──────────────────
server {
    listen 80;
    listen [::]:80;
    server_name minecraft.yourssu.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── HTTPS (443): BlueMap + MCSManager 패널 ─────────────────
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name minecraft.yourssu.com;

    ssl_certificate     /etc/letsencrypt/live/minecraft.yourssu.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/minecraft.yourssu.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Docker 내장 DNS — 컨테이너명 런타임 해석용
    resolver 127.0.0.11 valid=30s ipv6=off;

    # /admin → /admin/ 리디렉션
    location = /admin {
        return 301 /admin/;
    }

    # MCSManager 관리 패널
    #   - proxy_pass 트레일링 슬래시로 /admin/ 프리픽스 제거
    #   - sub_filter로 <base href="/admin/"> 주입 (Vue Router SPA 경로 인식)
    location /admin/ {
        set $mcs_web http://mcsmanager-web:23333;
        proxy_pass         $mcs_web/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_read_timeout 86400s;

        sub_filter_once on;
        sub_filter '<head>' '<head><base href="/admin/">';
    }

    # BlueMap 3D 지도 (루트)
    location / {
        set $bluemap http://minecraft-paper:8100;
        proxy_pass         $bluemap;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}

# ── SSL :24444: MCSManager 데몬 WebSocket ──────────────────
#
#   MCSManager v4 는 브라우저 → 데몬 간 WebSocket을 직접 연결한다.
#   브라우저에서 mcsmanager-daemon:24444 는 해석 불가이므로
#   nginx가 SSL로 외부에 노출한 뒤 내부 컨테이너로 프록시한다.
#
#   방화벽: sudo ufw allow 24444/tcp
#
#   MCSManager 패널에서 노드(데몬) 등록 시:
#     주소: minecraft.yourssu.com
#     포트: 24444
#     HTTPS: ON
server {
    listen 24444 ssl;
    listen [::]:24444 ssl;
    server_name minecraft.yourssu.com;

    ssl_certificate     /etc/letsencrypt/live/minecraft.yourssu.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/minecraft.yourssu.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    resolver 127.0.0.11 valid=30s ipv6=off;

    location / {
        set $mcs_daemon http://mcsmanager-daemon:24444;
        proxy_pass         $mcs_daemon;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_read_timeout 86400s;
    }
}
