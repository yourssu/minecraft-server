server {
    listen 80;
    listen [::]:80;
    server_name minecraft.yourssu.com;

    root /var/www/minecraft-yourssu;
    index index.html;

    location /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name minecraft.yourssu.com;

    root /var/www/minecraft-yourssu;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/minecraft.yourssu.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/minecraft.yourssu.com/privkey.pem;

    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        try_files $uri $uri/ /index.html;
    }
}
