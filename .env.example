# Host runtime
TZ=Asia/Seoul
PUID=1000
PGID=1000

# Minecraft runtime
MC_MEMORY=8G
MC_PORT=25565
BEDROCK_PORT=19132

# World / gameplay
MC_LEVEL=world
MC_MODE=survival
MC_DIFFICULTY=normal
MAX_PLAYERS=50
VIEW_DISTANCE=8
SIMULATION_DISTANCE=10
ONLINE_MODE=FALSE
ENABLE_WHITELIST=FALSE
ENFORCE_WHITELIST=FALSE
WHITELIST=
OPS=
MOTD=yourssu 2026
PVP=TRUE
ALLOW_FLIGHT=TRUE
ENABLE_COMMAND_BLOCK=TRUE
ENABLE_QUERY=FALSE

# Admin / JVM
RCON_PASSWORD=replace-with-a-strong-password
USE_AIKAR_FLAGS=TRUE

# HTTPS / Let's Encrypt
LETSENCRYPT_DOMAIN=minecraft.yourssu.com
LETSENCRYPT_EMAIL=

# Plugin auto-install
MODRINTH_DOWNLOAD_DEPENDENCIES=required
SPIGET_RESOURCES=34315,90766

# Power saving
ENABLE_AUTOPAUSE=FALSE
AUTOPAUSE_TIMEOUT_EST=3600

# Backups
BACKUP_NAME=world
BACKUP_METHOD=tar
BACKUP_INTERVAL=12h
PRUNE_BACKUPS_DAYS=7
PAUSE_IF_NO_PLAYERS=FALSE
